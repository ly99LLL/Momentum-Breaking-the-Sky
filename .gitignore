# ============================================================
# 势·破空 (SHI: Shattering the Void) — .gitignore
# ============================================================

# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# === Rust / Tauri ===
target/
src-tauri/target/
*.rs.bk
*.pdb

# === 构建产物 ===
dist/
build/
out/
*.exe
*.msi
*.dmg
*.app
*.AppImage

# === WebAssembly ===
*.wasm

# === 环境变量 ===
.env
.env.local
.env.*.local
*.env

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*
code-workspace

# === 操作系统 ===
Thumbs.db
.DS_Store
Desktop.ini
$RECYCLE.BIN/

# === 日志 ===
*.log
logs/

# === 测试 ===
coverage/
.nyc_output/

# === 临时文件 ===
*.tmp
*.temp
tmp/
temp/
.cache/

# === 印记导出（开发测试产物） ===
test-imprints/
